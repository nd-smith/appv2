{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaimX Event",
  "description": "Schema for ClaimX events",
  "type": "object",
  "required": ["eventType"],
  "properties": {
    "eventType": {
      "type": "string",
      "description": "Type of ClaimX event"
    },
    "projectId": {
      "type": "string",
      "description": "ClaimX project identifier"
    },
    "taskAssignmentId": {
      "type": "string",
      "description": "ClaimX task assignment identifier"
    },
    "mediaId": {
      "type": "string",
      "description": "ClaimX media identifier"
    },
    "mediaIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "ClaimX media identifiers associated with the event"
    },
    "masterFileName": {
      "type": "string",
      "description": "Master file name for the event payload"
    },
    "videoCollaborationId": {
      "type": "string",
      "description": "ClaimX video collaboration identifier"
    }
  },
  "additionalProperties": true
}
