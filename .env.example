# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ClaimX Event Hub
CLAIMX_EVENTHUB_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<key>;EntityPath=<eventhub>
# Optional if EntityPath is in the connection string above; required otherwise
CLAIMX_EVENTHUB_NAME=<eventhub-name>
